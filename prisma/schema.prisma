generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MarketSnapshot {
  id         Int      @id @default(autoincrement())
  timestamp  DateTime @default(now())

  buyPrice   Float
  sellPrice  Float
  spread     Float

  medianBuy  Float
  medianSell Float
  q1Buy      Float
  q3Buy      Float
  q1Sell     Float
  q3Sell     Float
  trimmedAds Int      @default(0)

  volume     Float?

  @@unique([timestamp])
  @@index([timestamp])
}
