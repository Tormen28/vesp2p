# Supabase REST endpoint (no Prisma needed - works on Cloudflare/Vercel Edge runtimes).
# Find these in: supabase.com -> Project -> Settings -> API
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SECRET_KEY="sb_secret_..."

# Secret token for the /api/cron endpoint.
# Cloudflare Cron Triggers / Vercel Cron send Authorization: Bearer ${CRON_SECRET}.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-secret-token-here"